# Supabase — Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Used by the Admin "invite/create user" route. NEVER expose to the browser.
# Project Settings -> API -> service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=

# Secret shared between Vercel Cron and the daily-backup route.
# Generate with: openssl rand -base64 32
# Set this same value in your Vercel project env vars.
CRON_SECRET=
